body {
    font-family: Arial, sans-serif;
    background-color: #f5f5f5;
    text-align: center;
    padding: 20px;
}

/* [Step 1] Navigation Menu Alignment */
.nav-menu {
    display: flex;
    justify-content: space-around; /* Distributes space evenly */
    max-width: 400px;
    margin: 0 auto 30px auto;
    background: #fff;
    padding: 10px;
    border-radius: 8px;
    border: 1px solid #ddd;
}

/* [Step 2] Horizontal Card Layout */
.content-wrapper {
    display: flex;
    justify-content: center; /* Centers the cards horizontally */
    gap: 30px;               /* Adds spacing between the two cards */
    flex-wrap: wrap;         /* Ensures cards stack on very small screens */
}

/* Card - Adjusted width for side-by-side layout */
.card {
    background: white;
    width: 300px;
    /* margin: 80px auto;  <- Removed auto margin to let Flexbox control positioning */
    padding: 20px;
    border: 2px solid #333;
    border-radius: 10px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

/* [Step 3] Fix Image Overflow */
.card img {
    /* width: 1000px; */     /* Commented out the fixed large size */
    max-width: 100%;         /* Ensures image stays within the card */
    height: auto;            /* Maintains aspect ratio */
    border-radius: 50%;
    margin-bottom: 20px;
}

/* Name */
.card h1 {
    font-size: 20px;
    color: #333;
    margin-bottom: 20px;
}

/* Text */
.card p {
    color: #666;
    font-size: 14px;
    margin-bottom: 20px;
}

/* Highlight role */
.card p:first-of-type {
    color: #007bff;
    font-weight: bold;
}

/* Button spacing */
button {
    cursor: pointer;
    padding: 5px 15px;
}
